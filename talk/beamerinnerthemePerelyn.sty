\ProvidesPackage{beamerinnerthemePerelyn}[2026/05/12 v1.0 Perelyn inner theme]
\mode<presentation>

%% Small filled squares — matches the PPT bullet style
\setbeamertemplate{itemize item}     {\raisebox{0.15ex}{\rule{0.55ex}{0.55ex}}}
\setbeamertemplate{itemize subitem}  {\raisebox{0.15ex}{\rule{0.45ex}{0.45ex}}}
\setbeamertemplate{itemize subsubitem}{\raisebox{0.15ex}{\rule{0.38ex}{0.38ex}}}

%% No Beamer navigation bar
\setbeamertemplate{navigation symbols}{}

%% Flat blocks (no shadow, no rounded corners — clean minimal look)
\setbeamertemplate{blocks}[default]

\mode<all>
